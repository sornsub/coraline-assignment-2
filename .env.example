# Local Docker Compose environment variable template.
# Copy this file to .env and fill in real values.
# Never commit .env — it should stay in .gitignore.

APP_ENV=local
API_URL=http://localhost:8000
AIRFLOW_URL=http://localhost:8081
NOTEBOOK_URL=http://localhost:8888
GRAFANA_URL=http://localhost:3000
EXAMPLE_API_TOKEN=replace-with-local-demo-value

# Airflow standalone admin password (local demo only)
AIRFLOW_ADMIN_PASSWORD=change-me-local-only

# Alertmanager webhook URL
# Get a free test receiver at https://webhook.site — copy the unique URL shown there.
# Set this to your real URL so Alertmanager can forward alert notifications.
# Do not commit your real URL to this file.
ALERT_WEBHOOK_URL=https://webhook.site/2c5b713a-5aa0-4f1d-bca3-c84240d53398
